# Runtime files
.download_pid

# Downloaded tools and binaries (large, re-downloadable)
tools/
!scripts/tools/

# Offline content (ZIM files, very large)
content/

# Cloned source repositories (re-cloneable)
sources/

# Large binary assets (Ollama installers)
assets/ollama/

# OS and editor files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Build artifacts
build/
dist/
*.o
*.a
*.so
*.dylib
*.dll

# Web UI runtime symlinks (created by update.sh link_tools)
web-ui/tools
web-ui/sources
web-ui/assets
web-ui/content

# Playwright screenshot tests
tests/screenshots/node_modules/
test-results/
docs/screenshots/.last-run.json

# Logs
*.log
logs/
