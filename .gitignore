# Runtime files
.download_pid

# Claude Code session / agent worktrees
.claude/

# Local machine config (host-specific paths, tokens, fleet) — never commit
.env
.valark.conf

# Downloaded tools and binaries (large, re-downloadable)
tools/
!scripts/tools/

# Repo-root data trees that live on the data disk. These are SYMLINKS at
# runtime (repo/<name> -> $VAL_ARK_DATA/...), and git treats a symlink as a
# file, so the trailing-slash dir patterns above don't catch them. Anchor to
# the repo root with no trailing slash so both real dirs and symlinks match.
# (Leading "/" keeps scripts/tools etc. unaffected.)
/tools
/models
/content
/sources
/assets
/installers
/state

# Service runtime state can hold generated credentials in dev/fallback mode
# (VAL_ARK_DATA unset -> STATE_DIR=./state). Never let those reach the public repo.
state/
credentials.txt
admin-credentials.txt

# Offline content (ZIM files, very large)
content/

# Cloned source repositories (re-cloneable)
sources/

# Large binary assets (Ollama installers)
assets/ollama/

# OS and editor files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Build artifacts
build/
dist/
*.o
*.a
*.so
*.dylib
*.dll

# Web UI runtime symlinks (created by update.sh link_tools)
web-ui/tools
web-ui/sources
web-ui/assets
web-ui/content

# Playwright screenshot tests
tests/screenshots/node_modules/
test-results/
docs/screenshots/.last-run.json

# Logs
*.log
logs/

# Python bytecode (planner.py etc. compiled by py_compile / imports)
__pycache__/
*.pyc

# Generated test results + report (regenerated by the suites)
tests/results/
